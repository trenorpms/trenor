# ─────────────────────────────────────────────────────────────
# TRENOR OPERATIVE CORE - PRODUCTION ENV CONFIGURATION TEMPLATE
# ─────────────────────────────────────────────────────────────
# Ensure all secrets are populated in your Railway Environment Settings.
# Do not commit populated production secrets to public source control.

PORT=4000
NODE_ENV=production

# Database Connection (Neon Serverless PostgreSQL)
DATABASE_URL=your_postgres_connection_string_here

# AI Engine Core
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Cloudflare R2 Secure Object Storage
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=your_r2_bucket_name_here
NEXT_PUBLIC_R2_PUBLIC_URL=your_r2_public_url_here

# Payment Engine (Stripe Integration)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Event Orchestration & Autonomous Agent State (Upstash Redis)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Client Apps Public Config (Adjust URLs to match actual Railway deployment domains)
NEXT_PUBLIC_API_URL=https://your-backend-railway-domain.up.railway.app/api
